<nav>
    <img class="nav-image" src="/assets/fp4-notches.svg" alt="" aria-hidden="true">
    <button class="nav-toggle" aria-label="Open navigation" aria-expanded="false">&#9776;</button>
    <div class="nav-links">
        {%- for item in collections.all | eleventyNavigation -%}
            <a href="{{ item.url }}" {% if item.url == page.url %}class="active"{% endif %}>{{ item.title }}</a>
        {%- endfor -%}
    </div>
    <div class="theme-switcher" role="group" aria-label="Color theme">
        <button class="theme-btn" data-theme="" aria-label="Default theme" aria-pressed="false" title="Default"></button>
        <button class="theme-btn" data-theme="dusk" aria-label="Dusk theme" aria-pressed="false" title="Dusk"></button>
    </div>
</nav>
