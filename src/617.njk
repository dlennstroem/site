<div class="gallery-header">
    <p>I like to shoot panos. They don't fit in the regular gallery grid, hence the separate page.</p>
</div>
<div class="gallery-container">
    <div class="masonry-grid masonry-pano" id="gallery">
        {% for image in gallery.pano.images %}
            <figure class="masonry-item">
                <button class="lightbox-trigger" data-full="{% getLightboxImage  image, 'pano' %}">
                    {% galleryImage image, 'pano' %}
                </button>
            </figure>
        {% endfor %}
    </div>
</div>

<div class="lightbox", id="lightbox" aria-hidden="true">
    <button class="lightbox-close" alias-label="Close image">&times;</button>
    <button class="lightbox-prev" alias-label="Previous image">&#10094;</button>
    <img class="lightbox-image" alt=""/>
    <button class="lightbox-next" alias-label="Next image">&#10095;</button>
    
</div>

<script src="/scripts/resizeGalleryItems.js"></script>
<script src="/scripts/lightbox.js" defer></script>